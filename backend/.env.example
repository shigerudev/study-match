# Copia a .env — no subir secretos al repo
PORT=3001

# Supabase → Project Settings → API
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Supabase → Project Settings → Database → Connection string (URI)
# Usa el modo "URI" con la contraseña de la base. Necesario solo para npm run db:setup
DATABASE_URL=postgresql://postgres.TU_REF:TU_PASSWORD@aws-0-XX.pooler.supabase.com:6543/postgres
